# ──────────────────────────────────────────────────────────────────────────────
# Template for the environment variables docker-compose needs.
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in REAL values in .env (especially the secrets).
#   3. docker compose up --build
#
# This .example file is committed to git so teammates know WHICH variables exist.
# The real .env is gitignored and NEVER committed — it holds the actual secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by the postgres container to initialize the DB, and reused by the app to
# build its connection (see DB_URL in docker-compose.yml).
POSTGRES_DB=finance_tracker
POSTGRES_USER=postgres
# Pick a strong password. This is a secret — do not reuse a real one here.
POSTGRES_PASSWORD=replace-with-a-strong-db-password

# ── JWT signing secret ────────────────────────────────────────────────────────
# Used to sign and verify auth tokens. Must be long and random. Anyone who knows
# it can forge logins. Generate one with, e.g.:  openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# ── Anthropic / Claude API key ────────────────────────────────────────────────
# Powers the AI features (categorization, budget advice, anomaly detection).
# Get one at https://console.anthropic.com. Leave blank to run without AI.
ANTHROPIC_API_KEY=sk-ant-your-key-here
